{
  "extraKnownMarketplaces": {
    "king": { "source": { "source": "github", "repo": "adamkingdotnet/config" } }
  },
  "enabledPlugins": { "king-agents@king": true },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git branch:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh run view:*)",
      "Bash(claude plugin list)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(ruff:*)",
      "Bash(ruff check:*)",
      "Bash(mypy:*)",
      "Bash(pytest:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(uv lock:*)",
      "Bash(pip install:*)",
      "Bash(pnpm install)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm test:*)",
      "Bash(npx tsc:*)",
      "WebSearch",
      "WebFetch(domain:raw.githubusercontent.com)"
    ],
    "deny": [],
    "ask": [
      "Bash(uv publish:*)",
      "Bash(python -m build:*)"
    ]
  }
}
