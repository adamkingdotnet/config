{
  "extraKnownMarketplaces": {
    "king": { "source": { "source": "github", "repo": "adamkingdotnet/config" } }
  },
  "enabledPlugins": { "king-agents@king": true },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git branch:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh run view:*)",
      "Bash(claude plugin list)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(tofu fmt:*)",
      "Bash(tofu validate:*)",
      "Bash(tofu plan:*)",
      "Bash(npx wrangler dev:*)",
      "WebSearch",
      "WebFetch(domain:raw.githubusercontent.com)"
    ],
    "deny": [],
    "ask": [
      "Bash(tofu apply:*)",
      "Bash(npx wrangler deploy:*)"
    ]
  }
}
